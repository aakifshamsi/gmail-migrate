# Cloudflare Worker token vault
WORKER_URL=https://your-worker.workers.dev
WORKER_AUTH_TOKEN=your-worker-auth-token

# Gmail accounts
GMAIL_SOURCE_USER=source@gmail.com      # G1 — source to free up
GMAIL_DEST1_USER=dest1@gmail.com        # G2 mirror
GMAIL_DEST2_USER=dest2@gmail.com        # G3 mirror

# GitHub (workflow dispatch + state file reads)
# Fine-grained PAT: Actions=read+write, Contents=read
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPO=owner/repo-name

# Public labels shown in the UI
NEXT_PUBLIC_SOURCE_LABEL=G1
NEXT_PUBLIC_DEST1_LABEL=G2
NEXT_PUBLIC_DEST2_LABEL=G3
NEXT_PUBLIC_GITHUB_REPO=owner/repo-name
